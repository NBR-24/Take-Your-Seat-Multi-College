{
  "rules": {
    "colleges": {
      "$collegeId": {
        ".read": true,
        ".write": "!data.exists()",
        "routes": {
          "$routeId": {
            "bogies": {
              "$bogieId": {
                ".read": true,
                ".write": true
              }
            },
            "bookings": {
              ".read": true,
              "$bookingId": {
                ".write": true
              }
            }
          }
        },
        "settings": {
          ".read": true,
