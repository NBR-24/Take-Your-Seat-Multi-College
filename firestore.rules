rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bogies collection - read access for all, write only for authenticated admin
    match /bogies/{bogieId} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users (admin) can write
    }
    
    // Bookings collection - read access for all, write with validation
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isValidBooking();
      allow update, delete: if request.auth != null; // Only admin can update/delete
      
      function isValidBooking() {
        let booking = request.resource.data;
        return booking.keys().hasAll(['id', 'bogieId', 'seatId', 'seatNumber', 'seatType', 'userName', 'email', 'phone', 'bookedAt', 'status']) &&
               booking.userName is string &&
               booking.userName.size() >= 2 &&
               booking.email is string &&
               booking.email.matches('.*@.*\\..*') &&
               booking.phone is string &&
               booking.phone.size() == 10 &&
               booking.status == 'confirmed';
      }
    }
    
    // Admin settings collection - only authenticated admin access
    match /adminSettings/{document} {
      allow read, write: if request.auth != null;
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
